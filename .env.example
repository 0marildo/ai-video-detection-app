# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_video_detection

# Authentication
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Sightengine API
SIGHTENGINE_API_USER=your-api-user
SIGHTENGINE_API_SECRET=your-api-secret
SIGHTENGINE_CALLBACK_URL=https://your-backend-url/api/v1/callback/sightengine

# CORS
CORS_ORIGINS=http://localhost:3000,https://your-frontend-url.vercel.app

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry (optional)
SENTRY_DSN=

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=
